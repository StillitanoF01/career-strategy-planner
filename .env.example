# Copy to `.env` and fill in. NEVER commit the real .env.
# These are read ONLY inside /api serverless functions (server-side).
# They are NOT prefixed with VITE_, so they are never exposed to the browser bundle.

# Adzuna — free key from https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Ticketmaster Discovery API — free key from https://developer.ticketmaster.com/
TICKETMASTER_KEY=
